# Copy to .env and fill in real values there. .env is gitignored;
# .env.example (this file) is committed, so never put real secrets here.

# Required to download model weights/tokenizer from Hugging Face.
HF_TOKEN=

# Required only when running the server with --gatekeeper (PersonaFlex
# language/topic gatekeeper). Used to call the Claude Haiku classifier that
# flags non-English or off-topic (non-U.S.-trucking) turns.
ANTHROPIC_API_KEY=